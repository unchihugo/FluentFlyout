<UserControl x:Class="FluentFlyout.Controls.CodexQuotaBarsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="34">
    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
        <Grid Name="SessionQuotaBarRow" Height="15" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="72" />
            </Grid.ColumnDefinitions>
            <TextBlock Name="SessionQuotaLabelText" Grid.Column="0" Text="session" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF7A4F" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <Border Name="SessionQuotaTrackBorder" Grid.Column="1" Height="3" Margin="0,0,6,0" Background="#33FFC400" CornerRadius="1.5" VerticalAlignment="Center" ClipToBounds="True">
                <Rectangle Name="SessionQuotaFillRectangle" Fill="#FFFFC400" HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" />
            </Border>
            <Border Grid.Column="2" Background="#33FF7043" Margin="0,1,2,1" CornerRadius="1">
                <TextBlock Name="SessionQuotaUsageText" Text="--/--" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF8764" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Border>
            <TextBlock Name="SessionQuotaPercentText" Grid.Column="3" Text="--%" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF8764" VerticalAlignment="Center" TextAlignment="Left" TextTrimming="CharacterEllipsis" />
            <TextBlock Name="SessionQuotaResetText" Grid.Column="4" Text="in --" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF8764" Margin="4,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        </Grid>
        <Grid Name="WeeklyQuotaBarRow" Height="15" Margin="0,2,0,0" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="72" />
            </Grid.ColumnDefinitions>
            <TextBlock Name="WeeklyQuotaLabelText" Grid.Column="0" Text="weekly" FontSize="10.5" FontWeight="SemiBold" Foreground="#FF43D68A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <Border Name="WeeklyQuotaTrackBorder" Grid.Column="1" Height="3" Margin="0,0,6,0" Background="#3343D68A" CornerRadius="1.5" VerticalAlignment="Center" ClipToBounds="True">
                <Rectangle Name="WeeklyQuotaFillRectangle" Fill="#FF00D26A" HorizontalAlignment="Left" RadiusX="1.5" RadiusY="1.5" />
            </Border>
            <Border Grid.Column="2" Background="#33FF7043" Margin="0,1,2,1" CornerRadius="1">
                <TextBlock Name="WeeklyQuotaUsageText" Text="--/--" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF8764" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Border>
            <TextBlock Name="WeeklyQuotaPercentText" Grid.Column="3" Text="--%" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF8764" VerticalAlignment="Center" TextAlignment="Left" TextTrimming="CharacterEllipsis" />
            <TextBlock Name="WeeklyQuotaResetText" Grid.Column="4" Text="in --" FontSize="10.5" FontWeight="SemiBold" Foreground="#FFFF8764" Margin="4,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        </Grid>
    </StackPanel>
</UserControl>
