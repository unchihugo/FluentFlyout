    <system:String x:Key="TaskbarVisualizerTitle">Vizualizér na hlavnom paneli</system:String>
    <system:String x:Key="TaskbarVisualizerDescription">Vizualizér zvuku v reálnom čase na vašom paneli úloh. Navrhnutý tak, aby mal minimálny vplyv na výkon moderných systémov.</system:String>
