<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="TitleText">Nastavenia FluentFlyout</system:String>
    <system:String x:Key="HomeTitle">Domov</system:String>
    <system:String x:Key="Enabled">Povolené</system:String>
    <system:String x:Key="Disabled">Vypnuté</system:String>
    <system:String x:Key="MediaFlyoutTitle">Plávajúce okno Prehrávača</system:String>
    <system:String x:Key="MediaFlyoutDescription">Pri počúvaní médií, stlačte ľubovoľnú klávesu pre ovládanie médií alebo hlasitosti (prehrať/pozastaviť, zvýšenie/zníženie hlasitosti atď.) na vašej klávesnici pre zobrazenie plávajúceho okna. Zobrazuje informácie o médiách, spolu s ovládacími prvkami prehrávania a ďalšími funkciami.</system:String>
    <system:String x:Key="TextBlockText1">Povoliť Plávajúce okno Prehrávača</system:String>
    <system:String x:Key="TextBlockText3">Zobraziť plávajúce okno keď stačíte klávesu pre ovládanie médií</system:String>
    <system:String x:Key="MediaFlyoutExcludeVolumeTitle">Vylúčiť klávesy hlasitosti</system:String>
    <system:String x:Key="MediaFlyoutExcludeVolumeDescription">Nezobrazovať plávajúce okno pri stlačení tlačidla na zvýšenie/zníženie hlasitosti/stlmenie zvuku</system:String>
    <system:String x:Key="TextBlockText2">Vyberte si z prednastavených moderných štýlov rozmazania pozadia</system:String>
    <system:String x:Key="BackgroundBlurOption1" xml:space="preserve"> Žiadne</system:String>
    <system:String x:Key="BackgroundBlurOption2" xml:space="preserve"> Štýl 1 (Cover Glow)</system:String>
    <system:String x:Key="BackgroundBlurOption3" xml:space="preserve"> Štýl 2 (Rising Glow)</system:String>
    <system:String x:Key="BackgroundBlurOption4" xml:space="preserve"> Štýl 3 (Blur)</system:String>
    <system:String x:Key="BackgroundBlurTitle">Rozmazanie pozadia</system:String>
    <system:String x:Key="AcrylicWindowTitle">Akrylové okno</system:String>
    <system:String x:Key="AcrylicWindowDescription">Použiť priehľadný akrylový efekt rozmazania pre plávajúce okno (vypnuté použije Mica)</system:String>
    <system:String x:Key="CompactLayoutTitle">Kompaktné rozloženie</system:String>
    <system:String x:Key="CompactLayoutDescription" xml:space="preserve">Štíhlejšie a menej rušivé rozloženie
skrýva informácie o opakovaní, náhodnom prehrávaní a prehrávači</system:String>
    <system:String x:Key="SelectedMonitorTitle">Cieľový monitor plávajúceho okna</system:String>
    <system:String x:Key="FlyoutPositionTitle">Pozícia plávajúceho okna</system:String>
    <system:String x:Key="PositionBottomLeft" xml:space="preserve"> Vľavo dole</system:String>
    <system:String x:Key="PositionBottomCenter" xml:space="preserve"> V strede dole</system:String>
    <system:String x:Key="PositionBottomRight" xml:space="preserve"> Vpravo dole</system:String>
    <system:String x:Key="PositionTopLeft" xml:space="preserve"> Vľavo hore</system:String>
    <system:String x:Key="PositionTopCenter" xml:space="preserve"> V strede hore</system:String>
    <system:String x:Key="PositionTopRight" xml:space="preserve"> Vpravo hore</system:String>
    <system:String x:Key="FlyoutStayDurationTitle">Doba zotrvania plávajúceho okna</system:String>
    <system:String x:Key="FlyoutStayDurationDescription">(predvolené: 3000ms)</system:String>
    <system:String x:Key="MillisecondsUnit">ms</system:String>
    <system:String x:Key="MediaFlyoutAlwaysDisplay">Vždy zobraziť</system:String>
    <system:String x:Key="MediaFlyoutAlwaysDisplayDescription">Plávajúce okno zostane otvorené, kým nekliknete na tlačidlo zavrieť</system:String>
    <system:String x:Key="CenterTitleArtistTitle">Vycentrovať názov pesničky a autora</system:String>
    <system:String x:Key="CenterTitleArtistDescription">Zarovnať text do stredu namiesto doľava</system:String>
    <system:String x:Key="ShowMediaPlayerNameTitle">Zobraziť názov prehrávača médií</system:String>
    <system:String x:Key="RepeatButtonTitle">Tlačidlo opakovania*</system:String>
    <system:String x:Key="RepeatButtonDescription">Vyberte medzi opakovaním všetkých alebo jednej pesničky, zväčšuje šírku plávajúceho okna</system:String>
    <system:String x:Key="ShuffleButtonTitle">Tlačidlo náhodného prehrávania*</system:String>
    <system:String x:Key="ShuffleButtonDescription">Zväčšuje šírku plávajúceho okna</system:String>
    <system:String x:Key="ShowSeekbarTitle">Zobraziť časovú os*</system:String>
    <system:String x:Key="ShowSeekbarDescription">Interaktívna časová os sa automaticky zobrazí, ak ju prehrávač podporuje</system:String>
    <system:String x:Key="UnsupportedControlsWarning">*Niektoré prehliadače/prehrávače nepodporujú ovládanie opakovania, náhodného prehrávania a časovej osi.</system:String>
    <system:String x:Key="PauseOtherMediaTitle">Automatické pozastavenie iných médií</system:String>
    <system:String x:Key="PauseOtherMediaDescription">Keď prehrávate alebo sa sústredíte na nové médiá, ostatné aktívne relácie sa automaticky pozastavia</system:String>
    <system:String x:Key="TaskbarWidgetCustomizationTitle">Widget na paneli úloh</system:String>
    <system:String x:Key="TaskbarWidgetDescription">Kompaktný vstavaný widget, ktorý sa nachádza priamo na paneli úloh systému Windows a poskytuje okamžitý prístup k médiám. Kliknutím na widget rozbalíte celé Plávajúce okno Prehrávača.</system:String>
    <system:String x:Key="TaskbarWidgetEnabledTitle">Povoliť widget na paneli úloh</system:String>
    <system:String x:Key="TaskbarWidgetEnabledDescription">Zobraziť kompaktný média widget na paneli úloh</system:String>
    <system:String x:Key="TaskbarWidgetVisualIssuesWarning">Ak máte problémy so zobrazením, upravte možnosti nižšie.</system:String>
    <system:String x:Key="TaskbarWidgetSelectedMonitorTitle">Cieľový monitor widgetu</system:String>
    <system:String x:Key="TaskbarWidgetPosition">Pozícia widgetu</system:String>
    <system:String x:Key="TaskbarWidgetPaddingSettingsTitle">Nastavenie odsadenia widgetu</system:String>
    <system:String x:Key="TaskbarWidgetPaddingSettingsDescription">Upravte odsadenie okolo widgetu tak, aby zodpovedalo štýlu vášho panela úloh</system:String>
    <system:String x:Key="TaskbarWidgetPaddingTitle">Tlačidlo Automatické odsadenie pre widgety systému Windows</system:String>
    <system:String x:Key="TaskbarWidgetPaddingDescription">Zapnite túto funkciu, ak máte povolené widgety systému Windows</system:String>
    <system:String x:Key="TaskbarWidgetManualPaddingTitle">Vlastné odsadenie</system:String>
    <system:String x:Key="TaskbarWidgetManualPaddingDescription">Pridá odsadenie navyše (predvolené: 0px)</system:String>
    <system:String x:Key="TaskbarWidgetBackgroundBlurTitle">Rozmazanie pozadia</system:String>
