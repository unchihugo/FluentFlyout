    <system:String x:Key="MediaFlyoutTitle">Plávajúce okno Prehrávača</system:String>
    <system:String x:Key="MediaFlyoutDescription">Pri počúvaní médií, stlačte ľubovoľnú klávesu pre ovládanie médií alebo hlasitosti (prehrať/pozastaviť, zvýšenie/zníženie hlasitosti atď.) na vašej klávesnici pre zobrazenie plávajúceho okna. Zobrazuje informácie o médiách, spolu s ovládacími prvkami prehrávania a ďalšími funkciami.</system:String>
    <system:String x:Key="TextBlockText1">Povoliť Plávajúce okno Prehrávača</system:String>
    <system:String x:Key="TextBlockText3">Zobraziť plávajúce okno keď stačíte klávesu pre ovládanie médií</system:String>
    <system:String x:Key="MediaFlyoutExcludeVolumeTitle">Vylúčiť klávesy hlasitosti</system:String>
    <system:String x:Key="MediaFlyoutExcludeVolumeDescription">Nezobrazovať plávajúce okno pri stlačení tlačidla na zvýšenie/zníženie hlasitosti/stlmenie zvuku</system:String>
    <system:String x:Key="TextBlockText2">Vyberte si z prednastavených moderných štýlov rozmazania pozadia</system:String>
    <system:String x:Key="BackgroundBlurOption1" xml:space="preserve"> Žiadne</system:String>
    <system:String x:Key="BackgroundBlurOption2" xml:space="preserve"> Štýl 1 (Cover Glow)</system:String>
    <system:String x:Key="BackgroundBlurOption3" xml:space="preserve"> Štýl 2 (Rising Glow)</system:String>
    <system:String x:Key="BackgroundBlurOption4" xml:space="preserve"> Štýl 3 (Blur)</system:String>
