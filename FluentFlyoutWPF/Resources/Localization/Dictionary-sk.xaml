    <system:String x:Key="TaskbarWidgetPaddingTitle">Tlačidlo Automatické odsadenie pre widgety systému Windows</system:String>
    <system:String x:Key="TaskbarWidgetPaddingDescription">Zapnite túto funkciu, ak máte povolené widgety systému Windows</system:String>
